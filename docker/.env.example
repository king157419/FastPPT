# ============================================
# FastPPT Production Environment Configuration
# ============================================

# -----------------
# API Keys (Required)
# -----------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# -----------------
# RAGFlow (Optional)
# -----------------
RAGFLOW_BASE_URL=https://your-ragflow-instance.com
RAGFLOW_API_KEY=your_ragflow_api_key_here
RAGFLOW_KB_ID=your_knowledge_base_id_here

# -----------------
# Database Configuration
# -----------------
POSTGRES_DB=fastppt
POSTGRES_USER=fastppt
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_PORT=5432

# -----------------
# Redis Configuration
# -----------------
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379
RAG_CACHE_TTL=3600

# -----------------
# Application Configuration
# -----------------
APP_ENV=production
LOG_LEVEL=info
BACKEND_PORT=8000
PPTXGENJS_PORT=3000
METRICS_PORT=9090

# -----------------
# CORS Configuration
# -----------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com

# -----------------
# Monitoring
# -----------------
ENABLE_METRICS=true

# -----------------
# Node.js Environment
# -----------------
NODE_ENV=production
