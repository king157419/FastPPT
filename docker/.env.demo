# FastPPT Docker contest demo profile
# Copy to docker/.env before `docker compose up`

# Required model key (set at least one)
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Contest-safe runtime defaults
CONTEST_FORCE_PLAIN=true
ENABLE_AGENT=false
REDIS_URL=
RAG_CACHE_TTL=3600

# Optional RAGFlow
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_KB_ID=

# Service ports
BACKEND_PORT=8000
PPTXGENJS_PORT=3000
POSTGRES_PORT=5432
METRICS_PORT=9090

# App
APP_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
