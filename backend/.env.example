# Core LLM keys (set at least one provider you use)
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=

# Demo-safe defaults (contest mode)
ENABLE_AGENT=false
REDIS_URL=
RAG_CACHE_TTL=3600

# Optional RAGFlow
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_KB_ID=

# Optional external PPTXGenJS service
PPTXGENJS_SERVICE_URL=http://localhost:3000

# Runtime
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
