# FastPPT contest demo profile
# Copy this file to backend/.env (or load it in docker compose) for stable demo defaults.

# Required LLM keys (set at least one provider you actually use)
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Demo-safe defaults: keep agent and Redis dependency off
ENABLE_AGENT=false
REDIS_URL=
RAG_CACHE_TTL=3600

# Optional RAGFlow (leave empty in contest demo)
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_KB_ID=

# Optional external PPTXGenJS service URL
PPTXGENJS_SERVICE_URL=http://localhost:3000

# App runtime
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
